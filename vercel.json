{
  "buildCommand": "npx --yes vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/install/:slug*",
      "destination": "/api/install/:slug*"
    }
  ],
  "headers": [
    {
      "source": "/install/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
