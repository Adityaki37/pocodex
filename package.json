{
  "name": "@crafter-station/pocodex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generate and browse Pokemon Codex pet packs inspired by Petdex and PMDCollab.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adityaki37/pocodex.git"
  },
  "homepage": "https://github.com/Adityaki37/pocodex",
  "bin": {
    "pocodex": "./bin/pocodex.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "npm run generate:pmd && npm run generate:pmd-rawasset",
    "generate:pokeapi": "node scripts/generate-pets.mjs",
    "generate:pmd": "node scripts/generate-pmd-pets.mjs",
    "generate:pmd-rawasset": "node scripts/generate-pmd-rawasset-pets.mjs",
    "generate:showdown": "node scripts/generate-showdown-pets.mjs",
    "site:data": "node scripts/build-site-data.mjs",
    "site:dev": "npx --yes vite --host 127.0.0.1",
    "site:quality": "node scripts/generate-blastoise-upscale-demo.mjs",
    "site:pixel-styles": "node scripts/generate-pixel-style-public-assets.mjs",
    "site:repair-pixel-assets": "node scripts/repair-pixel-style-manifest-assets.mjs",
    "site:audit-pixel-contract": "node scripts/audit-pixel-style-manifest-contract.mjs",
    "site:audit-base-coverage": "node scripts/audit-base-coverage.mjs",
    "site:build": "npm run site:data && npm run site:quality && npm run site:pixel-styles && npm run site:repair-pixel-assets && npx --yes vite build",
    "site:preview": "npx --yes vite preview --host 127.0.0.1",
    "validate": "node scripts/validate-pets.mjs",
    "install:pets": "node scripts/install-pets.mjs",
    "cli": "node bin/pocodex.mjs",
    "build": "npm run generate && npm run validate && npm run site:build",
    "sync": "npm run build && npm run install:pets"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "fast-xml-parser": "^5.7.2",
    "gifuct-js": "^2.1.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.21"
  }
}
